# ──────────────────────────────────────────────────────────────
# Voorbeeld-omgevingsvariabelen — kopieer naar `.env` en vul aan.
# (Het contactformulier draait op Netlify Forms en heeft GEEN sleutel nodig.)
# ──────────────────────────────────────────────────────────────

# De canonieke site-URL. Wordt gebruikt voor canonical links, Open Graph
# en de sitemap. Overschrijf alleen lokaal als je een andere URL test;
# in productie staat dit ook hard in astro.config.mjs.
# PUBLIC_SITE_URL="https://chrisonline.nl"

# AI-chat (Groq). Gratis sleutel: https://console.groq.com/keys
# Zonder deze sleutel geeft /api/chat een nette 503 terug (stub-modus).
# Zet 'm lokaal in `.env` en in productie in de Netlify-omgevingsvariabelen.
# GROQ_API_KEY="gsk_..."

# Offerte-aanvragen via /api/quote (Resend). https://resend.com/api-keys
# Zonder RESEND_API_KEY geeft /api/quote een nette 503.
# RESEND_API_KEY="re_..."
# Waar de notificatie naartoe gaat (default: chris@plugandpay.com).
# QUOTE_TO_EMAIL="info@chrisonline.nl"
# Afzender. Test kan met onboarding@resend.dev (levert alleen aan je eigen Resend-account).
# Zet naar een adres op een geverifieerd domein voor productie.
# QUOTE_FROM_EMAIL="aanvragen@chrisonline.nl"
# Zet op "true" PAS als chrisonline.nl in Resend is geverifieerd (DKIM/SPF).
# Dan pas wordt de auto-reply naar de bezoeker verstuurd.
# RESEND_DOMAIN_VERIFIED="false"
