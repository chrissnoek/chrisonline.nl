---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  /** Optioneel adresbalk-label (bijv. een domein). */
  url?: string;
  /** Laad eager voor above-the-fold beelden. */
  eager?: boolean;
}

const { src, alt, url, eager = false } = Astro.props;
---

<figure
  class="group shadow-card hover:shadow-card-hover overflow-hidden rounded-[0.9rem] border border-[var(--border)] bg-[var(--bg-alt)] transition-shadow duration-300"
>
  <!-- Browser-chrome -->
  <div class="flex items-center gap-3 border-b border-[var(--border)] bg-[var(--bg)] px-4 py-2.5">
    <span class="flex gap-1.5" aria-hidden="true">
      <span class="h-2.5 w-2.5 rounded-full bg-[#FF5F57]/70"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-[#FEBC2E]/70"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-[#28C840]/70"></span>
    </span>
    {
      url && (
        <span class="hidden flex-1 truncate rounded-md bg-[var(--bg-alt)] px-3 py-1 text-center text-xs text-[var(--fg-muted)] sm:block">
          {url}
        </span>
      )
    }
  </div>

  <!-- Screenshot: vaste viewport-ratio, toon de bovenkant van de pagina -->
  <div class="aspect-[16/10] overflow-hidden bg-white">
    <Image
      src={src}
      alt={alt}
      widths={[420, 640, 840]}
      sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 420px"
      format="avif"
      quality="mid"
      loading={eager ? 'eager' : 'lazy'}
      class="ease-out-soft h-full w-full object-cover object-top transition-transform duration-[1200ms] group-hover:object-bottom"
    />
  </div>
  <figcaption class="sr-only">{alt}</figcaption>
</figure>
