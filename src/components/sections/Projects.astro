---
import { getCollection } from 'astro:content';
import ProjectCard from '../ProjectCard.astro';
import Icon from '../Icon.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---

<section id="werk" class="scroll-mt-24" aria-labelledby="work-heading">
  <div class="container-page py-section">
    <div class="reveal-up flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-semibold tracking-wide text-[var(--accent-text)] uppercase">
          Geselecteerd werk
        </p>
        <h2 id="work-heading" class="mt-3 text-h2 font-bold text-balance">
          Projecten waar ontwerp en techniek samenkomen
        </h2>
      </div>
      <p class="max-w-sm text-[var(--fg-muted)]">
        Een greep uit recente projecten. Klik door voor de aanpak en het resultaat.
      </p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((project, i) => <ProjectCard project={project} eager={i === 0} />)}
    </div>

    <div class="reveal mt-10">
      <a
        href="/contact"
        class="group inline-flex items-center gap-2 font-semibold text-[var(--accent-text)]"
      >
        Ook zo'n project? Laten we praten
        <Icon name="arrowRight" size={18} class="transition-transform group-hover:translate-x-1" />
      </a>
    </div>
  </div>
</section>
