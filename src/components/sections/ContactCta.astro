---
import { CONTACT, SOCIALS } from '../../config/site';
import Icon from '../Icon.astro';
---

<section class="scroll-mt-24" aria-labelledby="cta-heading">
  <div class="container-page py-section">
    <div
      class="reveal-up rounded-card bg-ink-900 relative overflow-hidden px-6 py-14 text-center text-white sm:px-12 sm:py-20"
    >
      <!-- Accent-gloed -->
      <div class="pointer-events-none absolute inset-0" aria-hidden="true">
        <div
          class="bg-accent-500/20 absolute top-[-40%] left-1/2 h-[30rem] w-[30rem] -translate-x-1/2 rounded-full blur-3xl"
        >
        </div>
      </div>

      <div class="relative mx-auto max-w-2xl">
        <h2 id="cta-heading" class="text-h2 font-bold text-balance">
          Klaar voor een website die wél presteert?
        </h2>
        <p class="text-lead mt-4 text-pretty text-slate-300">
          Vertel me over je project. Of het nu een nieuwe website, webshop of redesign is, ik denk
          graag met je mee.
        </p>
        <div class="mt-9 flex flex-wrap justify-center gap-3">
          <a
            href="/contact"
            class="group rounded-pill bg-accent-500 hover:bg-accent-400 inline-flex items-center gap-2 px-7 py-3.5 font-semibold text-white transition-all hover:-translate-y-0.5"
          >
            Start een project
            <Icon
              name="arrowRight"
              size={18}
              class="transition-transform group-hover:translate-x-1"
            />
          </a>
          <a
            href={`mailto:${CONTACT.email}`}
            class="rounded-pill inline-flex items-center gap-2 border border-white/20 px-7 py-3.5 font-semibold text-white transition-colors hover:bg-white/10"
          >
            <Icon name="mail" size={18} />
            {CONTACT.email}
          </a>
        </div>

        <ul class="mt-9 flex justify-center gap-3">
          {
            SOCIALS.filter((s) => s.icon !== 'mail').map((social) => (
              <li>
                <a
                  href={social.url}
                  class="rounded-pill hover:border-accent-400 grid h-11 w-11 place-items-center border border-white/15 text-slate-300 transition-colors hover:text-white"
                  aria-label={`${social.name}, ${social.handle}`}
                  rel="me noopener"
                  target="_blank"
                >
                  <Icon name={social.icon} size={20} />
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
