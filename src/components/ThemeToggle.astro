---
import Icon from './Icon.astro';
---

<button
  type="button"
  id="theme-toggle"
  class="rounded-pill inline-flex h-10 w-10 items-center justify-center border border-[var(--border)] text-[var(--fg)] transition-colors hover:bg-[var(--bg-alt)]"
  aria-label="Wissel tussen licht en donker thema"
  aria-pressed="false"
>
  <Icon name="sun" size={20} class="hidden dark:block" />
  <Icon name="moon" size={20} class="block dark:hidden" />
</button>

<script>
  function syncToggle() {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    const isDark = document.documentElement.classList.contains('dark');
    btn.setAttribute('aria-pressed', String(isDark));
  }

  function bindToggle() {
    const btn = document.getElementById('theme-toggle');
    if (!btn || btn.dataset.bound) return;
    btn.dataset.bound = 'true';
    btn.addEventListener('click', () => {
      const root = document.documentElement;
      const isDark = root.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      syncToggle();
    });
  }

  // Eerste load én na elke View Transition-navigatie.
  document.addEventListener('astro:page-load', () => {
    bindToggle();
    syncToggle();
  });
</script>
