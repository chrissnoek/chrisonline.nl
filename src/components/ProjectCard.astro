---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import Icon from './Icon.astro';

interface Props {
  project: CollectionEntry<'projects'>;
  /** Eerste kaart laadt eager voor een snelle LCP; rest lazy. */
  eager?: boolean;
}

const { project, eager = false } = Astro.props;
const { data, id } = project;
---

<article
  class="reveal group rounded-card hover:shadow-card-hover relative flex flex-col overflow-hidden border border-[var(--border)] bg-[var(--bg-alt)] transition-all duration-300 hover:-translate-y-1"
>
  <a href={`/werk/${id}`} class="absolute inset-0 z-10" aria-label={`Bekijk project: ${data.title}`}
  ></a>

  <!-- Mockup met merkkleurige achtergrond-gradient -->
  <div
    class="relative aspect-[4/3] overflow-hidden"
    style={`background: radial-gradient(120% 120% at 80% 0%, ${data.accent}26, transparent 60%), var(--bg-alt);`}
  >
    <Image
      src={data.cover}
      alt={data.coverAlt}
      widths={[400, 640, 800]}
      sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw"
      format="avif"
      quality="mid"
      loading={eager ? 'eager' : 'lazy'}
      transition:name={`cover-${id}`}
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
    />
  </div>

  <div class="flex flex-1 flex-col p-6">
    <div class="flex items-center gap-2 text-sm text-[var(--fg-muted)]">
      <span class="font-medium text-[var(--accent-text)]">{data.role}</span>
      {
        data.placeholder && (
          <span class="rounded-pill bg-amber-500/15 px-2 py-0.5 text-xs font-medium text-amber-700 dark:text-amber-400">
            placeholder
          </span>
        )
      }
    </div>

    <h3 class="mt-2 text-xl font-bold tracking-tight">{data.title}</h3>
    <p class="mt-2 flex-1 text-sm leading-relaxed text-[var(--fg-muted)]">{data.summary}</p>

    <div class="mt-5 flex flex-wrap items-center gap-2">
      {
        data.skills.map((skill) => (
          <span class="rounded-pill border border-[var(--border)] px-2.5 py-1 text-xs font-medium text-[var(--fg-muted)]">
            {skill}
          </span>
        ))
      }
    </div>

    <span
      class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--accent-text)]"
    >
      Bekijk project
      <Icon name="arrowRight" size={16} class="transition-transform group-hover:translate-x-1" />
    </span>
  </div>
</article>
