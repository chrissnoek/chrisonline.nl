---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.vue';
import Icon from '../components/Icon.astro';
import { SITE, CONTACT, SOCIALS } from '../config/site';

const title = 'Contact';
const description =
  'Neem contact op met Chris Snoek voor een nieuwe website, webshop of redesign. ' +
  'Stuur een bericht of mail direct naar ' + CONTACT.email + '.';
---

<BaseLayout title={title} description={description}>
  <section class="container-page py-section" aria-labelledby="contact-heading">
    <div class="grid gap-12 lg:grid-cols-[1fr_1.1fr] lg:gap-16">
      <!-- Intro + gegevens -->
      <div>
        <p class="text-sm font-semibold tracking-wide text-[var(--accent-text)] uppercase">
          Contact
        </p>
        <h1 id="contact-heading" class="mt-3 text-h1 font-bold text-balance">
          Laten we je project bespreken
        </h1>
        <p class="mt-5 max-w-md text-lead text-[var(--fg-muted)] text-pretty">
          Heb je een idee, een vraag of een concreet project? Vul het formulier in of neem direct
          contact op. Ik reageer meestal binnen één werkdag.
        </p>

        <dl class="mt-10 space-y-6">
          <div class="flex items-start gap-4">
            <span
              class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-accent-500/12 text-[var(--accent-text)]"
            >
              <Icon name="mail" size={22} />
            </span>
            <div>
              <dt class="text-sm font-medium text-[var(--fg-muted)]">E-mail</dt>
              <dd>
                <a
                  href={`mailto:${CONTACT.email}`}
                  class="font-semibold text-[var(--accent-text)] hover:underline"
                >
                  {CONTACT.email}
                </a>
              </dd>
            </div>
          </div>
        </dl>

        <div class="mt-10">
          <p class="text-sm font-medium text-[var(--fg-muted)]">Volg {SITE.brand}</p>
          <ul class="mt-3 flex gap-3">
            {
              SOCIALS.map((social) => (
                <li>
                  <a
                    href={social.url}
                    class="grid h-11 w-11 place-items-center rounded-pill border border-[var(--border)] text-[var(--fg-muted)] transition-colors hover:border-accent-500 hover:text-[var(--accent-text)]"
                    aria-label={`${social.name} — ${social.handle}`}
                    rel={social.url.startsWith('http') ? 'me noopener' : undefined}
                    target={social.url.startsWith('http') ? '_blank' : undefined}
                  >
                    <Icon name={social.icon} size={20} />
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <!-- Formulier (Vue-island, alleen gehydrateerd wanneer zichtbaar) -->
      <div class="rounded-card border border-[var(--border)] bg-[var(--bg-alt)] p-6 sm:p-8">
        <ContactForm client:visible />
      </div>
    </div>
  </section>

  <!-- Verborgen statisch blueprint-formulier zodat Netlify het bij de build
       gegarandeerd detecteert (de AJAX-submit post naar dezelfde form-naam). -->
  <form
    name="contact"
    method="POST"
    data-netlify="true"
    netlify-honeypot="bot-field"
    action="/bedankt/"
    hidden
  >
    <input type="hidden" name="form-name" value="contact" />
    <input type="text" name="name" />
    <input type="email" name="email" />
    <textarea name="message"></textarea>
    <input name="bot-field" />
  </form>
</BaseLayout>
